---
import DocsLayout from '../layouts/DocsLayout.astro'
import ComponentDemo from '../components/ComponentDemo.astro'
import PropsTable from '../components/PropsTable.astro'
import SelectDemo from '../components/demos/SelectDemo'

const selectProps = [
  { name: 'label', type: 'string', default: '—', description: 'Label do select' },
  { name: 'options', type: 'SelectOption[]', default: '—', description: 'Array de opções {value, label, disabled?}' },
  { name: 'placeholder', type: 'string', default: '—', description: 'Opção inicial desabilitada como placeholder' },
  { name: 'error', type: 'string', default: '—', description: 'Mensagem de erro' },
  { name: 'helperText', type: 'string', default: '—', description: 'Texto auxiliar' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Desabilita o select' },
]
---
<DocsLayout title="Select">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[#0D1B26] mb-2">Select</h1>
    <p class="text-[#4A6070] text-base">Campo de seleção nativo com estilo customizado, suporte a label e erro.</p>
    <code class="text-xs font-mono text-[#0097D6] bg-[#EBF4FB] px-2 py-1 rounded mt-2 inline-block">import {'{ Select }'} from '@iit/ui'</code>
  </div>

  <h2 class="text-lg font-semibold text-[#0D1B26] mb-4">Variantes</h2>

  <ComponentDemo title="Default" code={`<Select options={[\n  { value: 'sp', label: 'São Paulo' },\n  { value: 'ba', label: 'Bahia' },\n]} />`}>
    <div class="w-72 relative">
      <select class="w-full appearance-none rounded-lg border border-[#D0DDE6] bg-white px-3 py-2 pr-9 text-sm text-[#0D1B26] focus:outline-none focus:ring-2 focus:ring-[#0097D6]">
        <option value="sp">São Paulo</option>
        <option value="ba">Bahia</option>
        <option value="rj">Rio de Janeiro</option>
      </select>
      <div class="absolute right-3 top-1/2 -translate-y-1/2 text-[#8A9FAF] pointer-events-none">▾</div>
    </div>
  </ComponentDemo>

  <ComponentDemo title="Com label e placeholder" code={`<Select label="Estado" placeholder="Selecione..." options={estados} />`}>
    <div class="w-72 flex flex-col gap-1.5">
      <label class="text-sm font-medium text-[#0D1B26]">Estado</label>
      <div class="relative">
        <select class="w-full appearance-none rounded-lg border border-[#D0DDE6] bg-white px-3 py-2 pr-9 text-sm text-[#0D1B26] focus:outline-none focus:ring-2 focus:ring-[#0097D6]">
          <option value="" disabled selected>Selecione um estado...</option>
          <option value="sp">São Paulo</option>
          <option value="ba">Bahia</option>
          <option value="rj">Rio de Janeiro</option>
        </select>
        <div class="absolute right-3 top-1/2 -translate-y-1/2 text-[#8A9FAF] pointer-events-none">▾</div>
      </div>
    </div>
  </ComponentDemo>

  <ComponentDemo title="Com erro" code={`<Select label="Categoria" error="Selecione uma categoria" />`}>
    <div class="w-72 flex flex-col gap-1.5">
      <label class="text-sm font-medium text-[#0D1B26]">Categoria</label>
      <div class="relative">
        <select class="w-full appearance-none rounded-lg border border-red-400 bg-white px-3 py-2 pr-9 text-sm text-[#0D1B26] focus:outline-none focus:ring-2 focus:ring-red-500" aria-invalid="true">
          <option value="" disabled selected>Selecione...</option>
          <option value="tech">Tecnologia</option>
        </select>
        <div class="absolute right-3 top-1/2 -translate-y-1/2 text-red-400 pointer-events-none">▾</div>
      </div>
      <p class="text-xs text-red-500" role="alert">Selecione uma categoria</p>
    </div>
  </ComponentDemo>

  <ComponentDemo title="Disabled" code={`<Select disabled label="Plano" />`}>
    <div class="w-72 flex flex-col gap-1.5">
      <label class="text-sm font-medium text-[#0D1B26]">Plano</label>
      <div class="relative">
        <select disabled class="w-full appearance-none rounded-lg border border-[#D0DDE6] bg-white px-3 py-2 pr-9 text-sm text-[#0D1B26] opacity-40 cursor-not-allowed">
          <option>Gratuito</option>
          <option>Pro</option>
        </select>
        <div class="absolute right-3 top-1/2 -translate-y-1/2 text-[#8A9FAF] pointer-events-none">▾</div>
      </div>
    </div>
  </ComponentDemo>

  <h2 class="text-lg font-semibold text-[#0D1B26] mb-4 mt-8">Demo interativo</h2>
  <SelectDemo client:load />

  <h2 class="text-lg font-semibold text-[#0D1B26] mb-4 mt-8">Props</h2>
  <PropsTable props={selectProps} />
</DocsLayout>
