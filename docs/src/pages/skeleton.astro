---
import DocsLayout from '../layouts/DocsLayout.astro'
import ComponentDemo from '../components/ComponentDemo.astro'
import PropsTable from '../components/PropsTable.astro'

const skeletonProps = [
  { name: 'variant', type: "'block' | 'text' | 'circle'", default: "'block'", description: 'Formato do skeleton' },
  { name: 'width', type: 'string | number', default: '—', description: 'Largura (número = px, string = qualquer unidade)' },
  { name: 'height', type: 'string | number', default: '—', description: 'Altura (número = px, string = qualquer unidade)' },
]
---
<DocsLayout title="Skeleton">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-[#0D1B26] mb-2">Skeleton</h1>
    <p class="text-[#4A6070] text-base">Placeholders animados para estados de carregamento. Três variantes: block, text e circle.</p>
    <code class="text-xs font-mono text-[#0097D6] bg-[#EBF4FB] px-2 py-1 rounded mt-2 inline-block">import {'{ Skeleton }'} from '@iit/ui'</code>
  </div>

  <h2 class="text-lg font-semibold text-[#0D1B26] mb-4">Variantes</h2>

  <ComponentDemo title="block — Retângulo arredondado" code={`<Skeleton variant="block" width={240} height={120} />\n<Skeleton variant="block" width={160} height={80} />`}>
    <div class="animate-pulse bg-[#D0DDE6] rounded-lg" style="width:240px;height:120px"></div>
    <div class="animate-pulse bg-[#D0DDE6] rounded-lg" style="width:160px;height:80px"></div>
    <div class="animate-pulse bg-[#D0DDE6] rounded-lg" style="width:100px;height:60px"></div>
  </ComponentDemo>

  <ComponentDemo title="text — Linha de texto" code={`<Skeleton variant="text" width="80%" />\n<Skeleton variant="text" width="60%" />\n<Skeleton variant="text" width="40%" />`}>
    <div class="w-80 flex flex-col gap-2">
      <div class="animate-pulse bg-[#D0DDE6] rounded h-4" style="width:80%"></div>
      <div class="animate-pulse bg-[#D0DDE6] rounded h-4" style="width:65%"></div>
      <div class="animate-pulse bg-[#D0DDE6] rounded h-4" style="width:40%"></div>
    </div>
  </ComponentDemo>

  <ComponentDemo title="circle — Avatar circular" code={`<Skeleton variant="circle" width={48} height={48} />\n<Skeleton variant="circle" width={64} height={64} />`}>
    <div class="animate-pulse bg-[#D0DDE6] rounded-full" style="width:32px;height:32px"></div>
    <div class="animate-pulse bg-[#D0DDE6] rounded-full" style="width:48px;height:48px"></div>
    <div class="animate-pulse bg-[#D0DDE6] rounded-full" style="width:64px;height:64px"></div>
    <div class="animate-pulse bg-[#D0DDE6] rounded-full" style="width:96px;height:96px"></div>
  </ComponentDemo>

  <ComponentDemo title="Card de perfil com skeleton" code={`// Composição realista\n<div class="flex gap-3">\n  <Skeleton variant="circle" width={48} height={48} />\n  <div class="flex flex-col gap-2 flex-1">\n    <Skeleton variant="text" width="60%" />\n    <Skeleton variant="text" width="40%" />\n  </div>\n</div>\n<Skeleton variant="block" width="100%" height={160} />`} noPad>
    <div class="p-6 w-80 flex flex-col gap-4">
      <div class="flex gap-3 items-center">
        <div class="animate-pulse bg-[#D0DDE6] rounded-full shrink-0" style="width:48px;height:48px"></div>
        <div class="flex flex-col gap-2 flex-1">
          <div class="animate-pulse bg-[#D0DDE6] rounded h-4" style="width:60%"></div>
          <div class="animate-pulse bg-[#D0DDE6] rounded h-3" style="width:40%"></div>
        </div>
      </div>
      <div class="animate-pulse bg-[#D0DDE6] rounded-lg w-full" style="height:140px"></div>
      <div class="flex flex-col gap-1.5">
        <div class="animate-pulse bg-[#D0DDE6] rounded h-3 w-full"></div>
        <div class="animate-pulse bg-[#D0DDE6] rounded h-3" style="width:80%"></div>
        <div class="animate-pulse bg-[#D0DDE6] rounded h-3" style="width:60%"></div>
      </div>
    </div>
  </ComponentDemo>

  <h2 class="text-lg font-semibold text-[#0D1B26] mb-4 mt-8">Props</h2>
  <PropsTable props={skeletonProps} />
</DocsLayout>
