---
export interface Props {
  name: string
  hex: string
  textDark?: boolean
}
const { name, hex, textDark = false } = Astro.props
---
<div class="flex flex-col rounded-xl overflow-hidden border border-[#D0DDE6] shadow-sm w-36">
  <div class="h-16 w-full" style={`background-color: ${hex}`}></div>
  <div class="bg-white px-3 py-2">
    <p class="text-xs font-semibold text-[#0D1B26] truncate">{name}</p>
    <p class="text-xs font-mono text-[#8A9FAF] mt-0.5">{hex}</p>
  </div>
</div>
