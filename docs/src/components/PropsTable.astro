---
export interface Prop {
  name: string
  type: string
  default?: string
  description: string
}
export interface Props {
  props: Prop[]
}
const { props } = Astro.props
---
<div class="rounded-xl border border-[#D0DDE6] overflow-hidden mb-8">
  <table class="w-full text-sm">
    <thead>
      <tr class="bg-[#F5F8FA] border-b border-[#D0DDE6]">
        <th class="text-left px-4 py-3 text-xs font-semibold text-[#4A6070] uppercase tracking-wide">Prop</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-[#4A6070] uppercase tracking-wide">Tipo</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-[#4A6070] uppercase tracking-wide">Default</th>
        <th class="text-left px-4 py-3 text-xs font-semibold text-[#4A6070] uppercase tracking-wide">Descrição</th>
      </tr>
    </thead>
    <tbody>
      {props.map((prop, i) => (
        <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#F5F8FA]'}>
          <td class="px-4 py-3 font-mono text-xs text-[#0097D6] font-medium">{prop.name}</td>
          <td class="px-4 py-3 font-mono text-xs text-[#8A9FAF]">{prop.type}</td>
          <td class="px-4 py-3 font-mono text-xs text-[#4A6070]">{prop.default ?? '—'}</td>
          <td class="px-4 py-3 text-xs text-[#4A6070]">{prop.description}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
